<nav class="navbar navbar-expand-lg" style="background-color: #e75f10;">
    <div class="container d-flex align-items-center justify-content-between">
        <div></div>

        <div class="d-flex align-items-center gap-3 ms-auto">
            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                
                <% if (currentUser.role === 'admin') { %>
                    <button class="btn btn-danger btn-sm rounded-pill fw-bold px-3 text-uppercase shadow-sm">
                        Quản trị viên
                    </button>
                <% } else { %>
                    <button class="btn btn-success btn-sm rounded-pill fw-bold px-3 text-uppercase shadow-sm">
                        Nhân viên
                    </button>
                <% } %>

                <a href="/user"
                    class="rounded-circle bg-white text-primary d-flex align-items-center justify-content-center shadow-sm text-decoration-none"
                    style="width: 32px; height: 32px;" title="Xin chào, <%= currentUser.fullName %>!">
                    <i class="bi bi-person-circle fs-5"></i>
                </a>

                <% if (currentUser.role === 'admin') { %>
                    <a class="btn btn-light btn-sm border text-dark fw-semibold" href="/activitylog" title="Nhật ký hệ thống">
                        <i class="bi bi-clock-history me-1"></i>Lịch sử
                    </a>
                <% } %>

                <a class="btn btn-light btn-sm border text-danger fw-semibold" href="/auth/logout">
                    <i class="bi bi-box-arrow-right me-1"></i>Đăng Xuất
                </a>

            <% } else { %>
                <a class="btn btn-light btn-sm fw-bold text-primary shadow-sm" href="/auth/login">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Đăng Nhập
                </a>
            <% } %>
        </div>
    </div>
</nav>