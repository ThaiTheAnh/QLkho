        .footer-social { transition: transform 0.3s ease, color 0.3s ease; }
        .footer-social:hover { color: #f36f21 !important; transform: translateY(-3px); }
    </style>

    <button type="button"
        class="btn btn-warning border-0 shadow rounded-circle d-flex align-items-center justify-content-center"
        id="btnBackToTop"
        style="position: fixed; bottom: 30px; right: 30px; z-index: 1060; width: 45px; height: 45px; padding: 0; display: none !important; transition: all 0.3s;">
        <i class="bi bi-chevron-up text-dark fw-bold" style="font-size: 1.2rem;"></i>
    </button>

    <script>
        const mybutton = document.getElementById("btnBackToTop");

        window.onscroll = function () {
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
                mybutton.style.setProperty("display", "flex", "important");
            } else {
                mybutton.style.setProperty("display", "none", "important");
            }
        };

        mybutton.addEventListener("click", function () {
            window.scrollTo({
                top: 0,
                behavior: "smooth"
            });
        });
    </script>

