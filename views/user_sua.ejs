<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css"> 
    <title><%= title %> | Kho FTEL</title>
</head>

<body>
    <div class="container">
        <%- include('includes/header') %>
    </div>
    <%- include('includes/navbar') %>
    
    <div class="d-flex">
        <div class="sidebar d-flex flex-column p-3">
                <a href="/" class="d-flex align-items-center mb-4 text-decoration-none text-primary">
                    <div>
                        <img src="/images/fpt.png" alt="FPT" height="40" class="me-2">
                        <p style="color :black"><b>FPT Telecom An Giang</b></p>
                    </div>
                </a>

                <ul class="nav flex-column mb-auto">
                    <li class="nav-item">
                        <a href="#collapseDanhMuc" data-bs-toggle="collapse" aria-expanded="false"
                            class="nav-link d-flex justify-content-between align-items-center">
                            <div><i class="bi bi-list-ul text-secondary"></i> Hệ thống</div>
                            <i class="bi bi-caret-right-fill rotate-icon"
                                style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                        </a>

                        <ul class="collapse nav flex-column ms-3" id="collapseDanhMuc">
                            <li class="nav-item">
                                <a href="/provider" class="nav-link">
                                    <i class="bi bi-shop text-secondary"></i> Nhà cung cấp
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/user" class="nav-link">
                                    <i class="bi bi-person-fill text-secondary"></i> Người dùng
                                </a>
                            </li>
                            <li class="nav-item"><a href="/request" class="nav-link "><i class="bi bi-file-earmark-text text-secondary"></i> Yêu cầu nhập hàng</a></li>
                            
                        </ul>
                    </li>

                    <li class="nav-item mt-1">
                        <a href="#collapseKhoThietBi" data-bs-toggle="collapse" aria-expanded="false"
                            class="nav-link d-flex justify-content-between align-items-center">
                            <div><i class="bi bi-building text-secondary"></i> Kho thiết bị</div>
                            <i class="bi bi-caret-right-fill rotate-icon"
                                style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                        </a>

                        <ul class="collapse nav flex-column ms-3" id="collapseKhoThietBi">
                            <li class="nav-item">
                                <a href="/unit" class="nav-link">
                                    <i class="bi bi-tag-fill text-secondary"></i> Đơn vị tính
                                </a>
                            </li>

                            <li class="nav-item">
                                <a href="/category" class="nav-link">
                                    <i class="bi bi-grid-fill text-secondary"></i> Danh mục thiết bị
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/product" class="nav-link">
                                    <i class="bi bi-box-seam text-secondary"></i> Thiết bị
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/inventory" class="nav-link">
                                    <i class="bi-boxes text-secondary"></i> Tồn kho
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/importstocks" class="nav-link">
                                    <i class="bi bi-box-arrow-in-right text-secondary"></i> Nhập kho
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/exportstocks" class="nav-link">
                                    <i class="bi bi-box-arrow-right text-secondary"></i> Xuất kho
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>

            </div>

        <div class="main-content flex-grow-1 d-flex flex-column bg-light">
            
            <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0 fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>Cập nhật thông tin Người dùng</h4>
                    <nav aria-label="breadcrumb" class="mt-2">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/user" class="text-decoration-none">Người dùng</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa</li>
                        </ol>
                    </nav>
                </div>
            </div>

            <div class="p-4 flex-grow-1 overflow-auto">
                <div class="card border-0 shadow-sm rounded-3" style="max-width: 800px; margin: 0 auto;">
                    <div class="card-body p-4">
                        
                        <form action="/user/sua/<%= user._id %>" method="POST">
                            
                            <h6 class="fw-bold text-primary mb-3">1. Thông tin đăng nhập</h6>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="username" class="form-label fw-semibold">Tên đăng nhập</label>
                                    <input type="text" class="form-control bg-light text-muted" id="username" name="username" value="<%= user.userName %>" readonly>
                                    <small class="text-danger" style="font-size: 0.8rem;">* Tên đăng nhập không thể thay đổi</small>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="password" class="form-label fw-semibold text-warning">Mật khẩu mới (Tùy chọn)</label>
                                    <input type="password" class="form-control border-warning" id="password" name="password" placeholder="Bỏ trống nếu không muốn đổi...">
                                </div>
                            </div>

                            <hr class="text-muted my-4">
                            
                            <h6 class="fw-bold text-primary mb-3">2. Thông tin cá nhân </h6>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="fullName" class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="fullName" name="fullName" value="<%= user.fullName %>" required>
                                </div>
                                
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="phone" class="form-label fw-semibold">Số điện thoại</label>
                                    <input type="text" class="form-control" id="phone" name="phone" value="<%= user.phone || '' %>">
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label for="email" class="form-label fw-semibold">Email</label>
                                    <input type="email" class="form-control" id="email" name="email" value="<%= user.email || '' %>">
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-2">
                                <a href="/user" class="btn btn-light border">Hủy bỏ</a>
                                <button type="submit" class="btn btn-success px-4">
                                    <i class="bi bi-check2-circle me-1"></i> Lưu thay đổi
                                </button>
                            </div>

                        </form>
                        </div>
                </div>
            </div>

        </div>
    </div>
    
    <%- include('includes/footer') %>
    <%- include('includes/javascript') %>
</body>
</html>