<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <title><%= title %> | Kho FTEL</title>
</head>

<body>
    <div class="container">
        <%- include('includes/header') %>
    </div>
    
    <%- include('includes/navbar') %>

    <% if (currentUser && currentUser.role === 'admin') { %>
        <div class="d-flex" style="height: calc(100vh - 140px);">
            
            <div class="sidebar d-flex flex-column p-3 h-100 overflow-auto">
                <a href="/" class="d-flex align-items-center mb-4 text-decoration-none text-primary">
                    <div>
                        <img src="/images/fpt.png" alt="FPT" height="40" class="me-2">
                        <p style="color :black"><b>FPT Telecom An Giang</b></p>
                    </div>
                </a>

                <ul class="nav flex-column mb-auto">
                    <li class="nav-item">
                        <a href="#collapseDanhMuc" data-bs-toggle="collapse" aria-expanded="true" class="nav-link d-flex justify-content-between align-items-center">
                            <div><i class="bi bi-shield-lock text-secondary"></i> Quản trị viên</div>
                            <i class="bi bi-caret-right-fill rotate-icon" style="font-size: 0.8rem; transition: transform 0.3s; transform: rotate(90deg);"></i>
                        </a>
                        <ul class="collapse show nav flex-column ms-3" id="collapseDanhMuc">
                            <li class="nav-item"><a href="/user" class="nav-link"><i class="bi bi-people-fill text-secondary"></i> Quản lý Nhân viên</a></li>
                            <li class="nav-item">
                                <a href="/activitylog" class="nav-link text-primary fw-bold">
                                    <i class="bi bi-journal-text text-primary"></i> Nhật ký Hoạt động
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item mt-3">
                        <a href="/inventory" class="nav-link"><i class="bi bi-box-arrow-left text-secondary"></i> Quay lại Kho</a>
                    </li>
                </ul>
            </div>

            <div class="main-content flex-grow-1 d-flex flex-column bg-light h-100 overflow-hidden">
                <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center flex-shrink-0">
                    <div>
                        <h4 class="mb-0 fw-bold text-dark"><i class="bi bi-clock-history me-2"></i>Nhật ký Hệ thống</h4>
                        <p class="text-muted small mb-0 mt-1">Lưu vết toàn bộ thao tác thêm, sửa, xóa của nhân viên.</p>
                    </div>
                    <div>
                        <button class="btn btn-outline-secondary btn-sm" onclick="window.location.reload()"><i class="bi bi-arrow-clockwise"></i> Làm mới</button>
                    </div>
                </div>

                <div class="p-4 flex-grow-1 overflow-auto">
                    <div class="card border-0 shadow-sm rounded-3 mb-4">
                        <div class="card-body">
                            <form action="/activitylog" method="GET" class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label text-muted fw-semibold small">Tìm kiếm nhân viên</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                                        <input type="text" class="form-control" name="search" placeholder="Nhập tên..." value="<%= typeof filters !== 'undefined' ? filters.search : '' %>">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label text-muted fw-semibold small">Từ ngày</label>
                                    <input type="date" class="form-control" name="startDate" value="<%= typeof filters !== 'undefined' ? filters.startDate : '' %>">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label text-muted fw-semibold small">Đến ngày</label>
                                    <input type="date" class="form-control" name="endDate" value="<%= typeof filters !== 'undefined' ? filters.endDate : '' %>">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted fw-semibold small">Loại hành động</label>
                                    <% let currentAction = (typeof filters !== 'undefined' && filters.actionType) ? filters.actionType : ''; %>
                                    <select class="form-select" name="actionType">
                                        <option value="" <%= currentAction === '' ? 'selected' : '' %>>-- Tất cả --</option>
                                        <option value="THÊM MỚI" <%= currentAction === 'THÊM MỚI' ? 'selected' : '' %>>Thêm mới</option>
                                        <option value="CẬP NHẬT" <%= currentAction === 'CẬP NHẬT' ? 'selected' : '' %>>Cập nhật / Sửa</option>
                                        <option value="XÓA/HỦY" <%= currentAction === 'XÓA/HỦY' ? 'selected' : '' %>>Xóa / Hủy</option>
                                    </select>
                                </div>
                                <div class="col-md-2 d-flex gap-2">
                                    <button type="submit" class="btn btn-primary flex-grow-1"><i class="bi bi-funnel"></i> Lọc</button>
                                    <a href="/activitylog" class="btn btn-light border" title="Xóa bộ lọc"><i class="bi bi-arrow-clockwise"></i></a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                                    <thead class="table-dark">
                                        <tr>
                                            <th scope="col" class="py-3 px-3" style="width: 15%">Thời gian</th>
                                            <th scope="col" class="py-3" style="width: 15%">Tài khoản</th>
                                            <th scope="col" class="py-3 text-center" style="width: 10%">SĐT</th>
                                            <th scope="col" class="py-3" style="width: 10%">Hành động</th>
                                            <th scope="col" class="py-3" style="width: 10%">Phân hệ</th>
                                            <th scope="col" class="py-3" style="width: 30%">Chi tiết thao tác</th>
                                            <th scope="col" class="py-3 text-center" style="width: 10%">IP Client</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (typeof logs !== 'undefined' && logs.length > 0) { %>
                                            <% logs.forEach(function(log) { %>
                                                <tr>
                                                    <td class="px-3 text-muted fw-semibold">
                                                        <%= new Date(log.createdAt).toLocaleString('vi-VN', { hour12: false }) %>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-light text-dark border px-2 py-1">
                                                            <i class="bi bi-person-circle me-1 text-secondary"></i> 
                                                            <%= log.user ? (log.user.fullName || log.user.userName) : 'Tài khoản đã xóa' %>
                                                        </span>
                                                    </td>
                                                    <td class="text-center fw-semibold text-primary">
                                                        <% if (log.user) { %>
                                                            <%= log.user.phone || log.user.phoneNumber || '---' %>
                                                        <% } else { %>
                                                            ---
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <% 
                                                            let badgeColor = 'bg-secondary';
                                                            if(log.action.includes('THÊM')) badgeColor = 'bg-success';
                                                            if(log.action.includes('CẬP NHẬT') || log.action.includes('SỬA')) badgeColor = 'bg-warning text-dark';
                                                            if(log.action.includes('XÓA') || log.action.includes('HỦY')) badgeColor = 'bg-danger';
                                                        %>
                                                        <span class="badge <%= badgeColor %> shadow-sm"><%= log.action %></span>
                                                    </td>
                                                    <td class="text-secondary fw-bold">
                                                        <%= log.module %>
                                                    </td>
                                                    <td class="text-dark">
                                                        <%= log.description %>
                                                    </td>
                                                    <td class="text-center text-muted small">
                                                        <%= log.ipAddress || 'Unknown' %>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="7" class="text-center py-5 text-muted">
                                                    <i class="bi bi-search fs-1 d-block mb-3 text-secondary opacity-50"></i>
                                                    Không tìm thấy dữ liệu phù hợp với bộ lọc.
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    
    <% } else { %>
        <div class="container mt-5 text-center">
             <div class="alert alert-danger shadow" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-3 d-block mb-2"></i>
                Truy cập bị từ chối! Bạn cần quyền quản trị viên (Admin) để xem nhật ký hệ thống.
             </div>
             <a href="/" class="btn btn-primary mt-3">Về Trang chủ</a>
        </div>
    <% } %>

    <%- include('includes/footer') %>
    <%- include('includes/javascript') %>
</body>
</html>