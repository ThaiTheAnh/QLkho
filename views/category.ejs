<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <title>
        <%= title %> | Kho FTEL
    </title>
</head>

<body>
    <div class="container">
        <%- include('includes/header') %>
    </div>
    <%- include('includes/navbar') %>

        <div class="d-flex">
            <div class="sidebar d-flex flex-column p-3">
                <a href="/" class="d-flex align-items-center mb-4 text-decoration-none text-primary">
                    <div>
                        <img src="/images/fpt.png" alt="FPT" height="40" class="me-2">
                        <p style="color :black"><b>FPT Telecom An Giang</b></p>
                    </div>
                </a>

                <ul class="nav flex-column mb-auto">
                    <li class="nav-item">
                        <a href="#collapseDanhMuc" data-bs-toggle="collapse" aria-expanded="false"
                            class="nav-link d-flex justify-content-between align-items-center">
                            <div><i class="bi bi-list-ul text-secondary"></i> Hệ thống</div>
                            <i class="bi bi-caret-right-fill rotate-icon"
                                style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                        </a>

                        <ul class="collapse nav flex-column ms-3" id="collapseDanhMuc">
                            <li class="nav-item">
                                <a href="/provider" class="nav-link">
                                    <i class="bi bi-shop text-secondary"></i> Nhà cung cấp
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/user" class="nav-link">
                                    <i class="bi bi-person-fill text-secondary"></i> Người dùng
                                </a>
                            </li>
                            <li class="nav-item"><a href="/request" class="nav-link "><i class="bi bi-file-earmark-text text-secondary"></i> Yêu cầu nhập hàng</a></li>
                            
                        </ul>
                    </li>

                    <li class="nav-item mt-1">
                        <a href="#collapseKhoThietBi" data-bs-toggle="collapse" aria-expanded="false"
                            class="nav-link d-flex justify-content-between align-items-center">
                            <div><i class="bi bi-building text-secondary"></i> Kho thiết bị</div>
                            <i class="bi bi-caret-right-fill rotate-icon"
                                style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                        </a>

                        <ul class="collapse nav flex-column ms-3" id="collapseKhoThietBi">
                            <li class="nav-item">
                                <a href="/unit" class="nav-link">
                                    <i class="bi bi-tag-fill text-secondary"></i> Đơn vị tính
                                </a>
                            </li>

                            <li class="nav-item">
                                <a href="/category" class="nav-link">
                                    <i class="bi bi-grid-fill text-secondary"></i> Danh mục thiết bị
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/product" class="nav-link">
                                    <i class="bi bi-box-seam text-secondary"></i> Thiết bị
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/inventory" class="nav-link">
                                    <i class="bi-boxes text-secondary"></i> Tồn kho
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/importstocks" class="nav-link">
                                    <i class="bi bi-box-arrow-in-right text-secondary"></i> Nhập kho
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/exportstocks" class="nav-link">
                                    <i class="bi bi-box-arrow-right text-secondary"></i> Xuất kho
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>

            </div>

            <div class="main-content flex-grow-1 d-flex flex-column bg-light">

                <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="mb-0 fw-bold text-primary"><i class="bi bi-grid-fill me-2"></i>Quản lý Danh mục thiết bị</h4>
                        <nav aria-label="breadcrumb" class="mt-2">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
                                <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Kho thiết bị</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Danh mục</li>
                            </ol>
                        </nav>
                    </div>
                    <div>
                        <a href="/category/them" class="btn btn-primary shadow-sm fw-semibold">
                            <i class="bi bi-plus-circle me-1"></i> Thêm Danh mục
                        </a>
                        
                    </div>
                </div>

                <div class="p-4 flex-grow-1 overflow-auto">
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th scope="col" class="text-center py-3" style="width: 5%">STT</th>
                                            <th scope="col" class="py-3" style="width: 40%">Tên Danh mục</th>
                                            <th scope="col" class="py-3" style="width: 20%">Ngày tạo</th>
                                            <th scope="col" class="text-center py-3" style="width: 15%">Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                                            <% categories.forEach(function(c, index) { %>
                                                <tr>
                                                    <td class="text-center fw-semibold text-muted">
                                                        <%= index + 1 %>
                                                    </td>
                                                    
                                                    <td class="fw-semibold text-dark">
                                                        <%= c.categoryName %> </td>
                                                    <td class="text-muted">
                                                        <%= new Date(c.createdAt).toLocaleDateString('vi-VN') %>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="d-flex justify-content-center gap-2">
                                                            <a href="/category/sua/<%= c._id %>"
                                                                class="btn btn-outline-primary btn-sm" title="Sửa">
                                                                <i class="bi bi-pencil-square"></i>
                                                            </a>

                                                            <% if (currentUser && currentUser.role==='admin' ) { %>
                                                                <a href="/category/xoa/<%= c._id %>"
                                                                    class="btn btn-outline-danger btn-sm" title="Xóa"
                                                                    onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                                                    <i class="bi bi-trash"></i>
                                                                </a>
                                                            <% } else { %>
                                                                <span class="text-muted mt-1" title="Chỉ Admin mới có quyền xóa">
                                                                    <i class="bi bi-shield-lock-fill fs-6"></i>
                                                                </span>
                                                            <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center py-5 text-muted">
                                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                                    Chưa có dữ liệu Danh mục nào. Hãy thêm mới!
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <%- include('includes/footer') %>
        <%- include('includes/javascript') %>
</body>

</html>