<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <title><%= title %> | Kho FTEL</title>
    <style>
        .serial-tag-container {
            display: flex; flex-wrap: wrap; gap: 5px; padding: 5px;
            border: 1px solid #dee2e6; border-radius: 0.375rem; background-color: #fff; min-height: 38px;
        }
        .serial-tag {
            background-color: #e9ecef; border: 1px solid #ced4da; border-radius: 3px;
            padding: 0 8px; display: flex; align-items: center; font-size: 0.85rem;
        }
        .serial-tag i { margin-left: 5px; cursor: pointer; color: #dc3545; }
        .serial-input-hidden { border: none; outline: none; flex-grow: 1; min-width: 100px; }
    </style>
</head>

<body>
    <div class="container">
        <%- include('includes/header') %>
    </div>

    <%- include('includes/navbar') %>

    <% if (currentUser) { %>
        <div class="d-flex" style="height: calc(100vh - 140px);">
            <div class="sidebar d-flex flex-column p-3 h-100 overflow-auto">
               <a href="/" class="d-flex align-items-center mb-4 text-decoration-none text-primary">
                    <div>
                        <img src="/images/fpt.png" alt="FPT" height="40" class="me-2">
                        <p style="color :black"><b>FPT Telecom An Giang</b></p>
                    </div>
                </a>

                <ul class="nav flex-column mb-auto">
                    <li class="nav-item">
                        <a href="#collapseDanhMuc" data-bs-toggle="collapse" aria-expanded="false" class="nav-link d-flex justify-content-between align-items-center">
                            <div><i class="bi bi-list-ul text-secondary"></i> Hệ thống</div>
                            <i class="bi bi-caret-right-fill rotate-icon" style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                        </a>
                        <ul class="collapse nav flex-column ms-3" id="collapseDanhMuc">
                            <li class="nav-item"><a href="/provider" class="nav-link"><i class="bi bi-shop text-secondary"></i> Nhà cung cấp</a></li>
                            <li class="nav-item"><a href="/user" class="nav-link"><i class="bi bi-person-fill text-secondary"></i> Người dùng</a></li>
                            <li class="nav-item"><a href="/request" class="nav-link "><i class="bi bi-file-earmark-text text-secondary"></i> Yêu cầu nhập hàng</a></li>
                        </ul>
                    </li>

                    <li class="nav-item mt-1">
                        <a href="#collapseKhoThietBi" data-bs-toggle="collapse" aria-expanded="true" class="nav-link d-flex justify-content-between align-items-center">
                            <div><i class="bi bi-building text-secondary"></i> Kho thiết bị</div>
                            <i class="bi bi-caret-right-fill rotate-icon" style="font-size: 0.8rem; transition: transform 0.3s; transform: rotate(90deg);"></i>
                        </a>
                        <ul class="collapse show nav flex-column ms-3" id="collapseKhoThietBi">
                            <li class="nav-item"><a href="/unit" class="nav-link"><i class="bi bi-tag-fill text-secondary"></i> Đơn vị tính</a></li>
                            <li class="nav-item"><a href="/category" class="nav-link"><i class="bi bi-grid-fill text-secondary"></i> Danh mục thiết bị</a></li>
                            <li class="nav-item"><a href="/product" class="nav-link"><i class="bi bi-box-seam text-secondary"></i> Thiết bị</a></li>
                            <li class="nav-item"><a href="/inventory" class="nav-link"><i class="bi bi-boxes text-secondary"></i> Tồn kho</a></li>
                            <li class="nav-item"><a href="/importstock" class="nav-link"><i class="bi bi-box-arrow-in-right text-secondary"></i> Nhập kho</a></li>
                            <li class="nav-item"><a href="/exportstock" class="nav-link text-danger fw-bold"><i class="bi bi-box-arrow-right text-danger"></i> Xuất kho</a></li>
                        </ul>
                    </li>
                </ul>
            </div>

            <div class="main-content flex-grow-1 d-flex flex-column bg-light h-100 overflow-hidden">
                <div class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center flex-shrink-0">
                    <div>
                        <h4 class="mb-0 fw-bold text-danger"><i class="bi bi-box-arrow-up-right me-2"></i>Lập Phiếu Xuất Kho</h4>
                        <nav aria-label="breadcrumb" class="mt-2">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item"><a href="/exportstock" class="text-decoration-none">Xuất kho</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Lập phiếu mới</li>
                            </ol>
                        </nav>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/exportstock" class="btn btn-secondary shadow-sm fw-semibold">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                    </div>
                </div>

                <div class="p-4 flex-grow-1 overflow-auto">
                    <form action="/exportstock/them" method="POST" id="exportForm">
                        <div class="row">
                            <div class="col-md-4 mb-4">
                                <div class="card border-0 shadow-sm rounded-3 h-100">
                                    <div class="card-header bg-white py-3 fw-bold text-dark border-bottom">
                                        <i class="bi bi-info-circle me-1 text-danger"></i> Thông tin phiếu xuất
                                    </div>
                                    <div class="card-body">
                                        
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Người nhận hàng <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control shadow-sm border-danger border-opacity-50" name="recipientName" placeholder="Tên KTV hoặc Khách hàng" required>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Số điện thoại</label>
                                            <input type="text" class="form-control shadow-sm" name="recipientPhone" placeholder="SĐT liên hệ (nếu có)">
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Lý do xuất kho <span class="text-danger">*</span></label>
                                            <input class="form-control shadow-sm" list="reasonOptions" name="reason" placeholder="VD: Bảo hành, Lắp đặt..." required>
                                            <datalist id="reasonOptions">
                                                <option value="Lắp đặt khách hàng mới">
                                                <option value="Bảo hành / Đổi trả thiết bị">
                                                <option value="Xuất sử dụng nội bộ (Văn phòng)">
                                                <option value="Triển khai hạ tầng mạng">
                                            </datalist>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Số hợp đồng / Phiếu ĐK</label>
                                            <input type="text" class="form-control shadow-sm" name="invoiceNumber" placeholder="Nhập số hợp đồng (nếu có)">
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-semibold">Ngày xuất kho</label>
                                            <input type="date" class="form-control shadow-sm" name="dateExport" id="todayDate" required>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-semibold text-muted" style="font-size: 0.9rem;">
                                                <i class="bi bi-person me-1"></i>Người lập: <%= currentUser.fullName || currentUser.userName %>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-8 mb-4">
                                <div class="card border-0 shadow-sm rounded-3 h-100">
                                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                                        <span class="fw-bold text-dark"><i class="bi bi-list-check me-1 text-danger"></i> Danh sách thiết bị xuất</span>
                                        <button type="button" class="btn btn-sm btn-outline-danger fw-semibold" id="btnAddRow">
                                            <i class="bi bi-plus-lg"></i> Thêm dòng
                                        </button>
                                    </div>
                                    <div class="card-body p-0">
                                        <div class="table-responsive">
                                            <table class="table table-borderless align-middle mb-0" id="itemsTable">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th style="width: 5%">#</th>
                                                        <th style="width: 30%">Tên thiết bị <span class="text-danger">*</span></th>
                                                        <th class="text-center" style="width: 10%">Kho còn</th>
                                                        <th style="width: 10%">SL <span class="text-danger">*</span></th>
                                                        <th style="width: 35%">Số SN</th>
                                                        <th style="width: 10%" class="text-center">Xóa</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="itemsBody">
                                                    <tr class="border-bottom item-row">
                                                        <td class="text-center text-muted row-number">1</td>
                                                        <td>
                                                            <select class="form-select product-select shadow-sm" name="productId" required>
                                                                <option value="" disabled selected>-- Chọn thiết bị xuất --</option>
                                                                <% if (typeof inventories !== 'undefined') { %>
                                                                    <% inventories.forEach(function(inv) { %>
                                                                        <option value="<%= inv.product._id %>" data-stock="<%= inv.quantity %>">
                                                                            [<%= inv.product.productID %>] <%= inv.product.productName %>
                                                                        </option>
                                                                    <% }) %>
                                                                <% } %>
                                                            </select>
                                                        </td>
                                                        <td class="text-center fw-bold text-danger stock-display">0</td>
                                                        <td>
                                                            <input type="number" class="form-control qty-input shadow-sm" name="quantity" min="1" required disabled placeholder="SL">
                                                        </td>
                                                        <td>
                                                            <div class="serial-tag-container" onclick="this.querySelector('input').focus()">
                                                                <input type="text" class="serial-input-hidden" placeholder="Nhập SN rồi Enter">
                                                            </div>
                                                            <input type="hidden" name="serialNumber" class="serial-data-hidden">
                                                        </td>
                                                        <td class="text-center">
                                                            <button type="button" class="btn btn-light text-danger btn-remove-row shadow-sm" disabled><i class="bi bi-trash"></i></button>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-2 pt-3 border-top">
                            <a href="/exportstock" class="btn btn-light border px-4 fw-semibold">Hủy bỏ</a>
                            <button type="submit" class="btn btn-danger px-5 shadow-sm fw-bold">
                                <i class="bi bi-send-check me-1"></i> XUẤT PHIẾU
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="container mt-5 text-center">
            <div class="alert alert-warning" role="alert">
                Vui lòng <a href="/auth/login" class="alert-link">đăng nhập</a> để truy cập hệ thống.
            </div>
        </div>
    <% } %>

    <%- include('includes/footer') %>
    <%- include('includes/javascript') %>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // 1. Tự động điền ngày hôm nay
            document.getElementById('todayDate').valueAsDate = new Date();

            const tbody = document.getElementById('itemsBody');
            const btnAddRow = document.getElementById('btnAddRow');
            const exportForm = document.getElementById('exportForm');

            // 🚨 BÙA CHỐNG TRÌNH DUYỆT TỰ ĐỘNG GỬI FORM KHI BẤM ENTER Ở BẤT KỲ ĐÂU
            exportForm.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') {
                    e.preventDefault(); 
                }
            });

            // 2. Cập nhật STT và Nút xóa
            function updateRows() {
                const rows = tbody.querySelectorAll('tr.item-row');
                rows.forEach((row, index) => {
                    row.querySelector('.row-number').textContent = index + 1;
                    const btnRemove = row.querySelector('.btn-remove-row');
                    if (rows.length === 1) {
                        btnRemove.disabled = true;
                        btnRemove.classList.replace('text-danger', 'text-muted');
                    } else {
                        btnRemove.disabled = false;
                        btnRemove.classList.replace('text-muted', 'text-danger');
                    }
                });
            }

            // 3. Thêm dòng mới
            btnAddRow.addEventListener('click', function () {
                const firstRow = tbody.querySelector('tr.item-row');
                const newRow = firstRow.cloneNode(true);

                newRow.querySelector('select').selectedIndex = 0;
                
                const qtyInput = newRow.querySelector('.qty-input');
                qtyInput.value = '';
                qtyInput.disabled = true; 

                newRow.querySelector('.stock-display').textContent = '0';
                
                newRow.querySelector('.serial-tag-container').innerHTML = '<input type="text" class="serial-input-hidden" placeholder="Nhập SN rồi Enter...">';
                newRow.querySelector('.serial-data-hidden').value = '';

                tbody.appendChild(newRow);
                updateRows();
            });

            // 4. Bắt sự kiện XÓA DÒNG và THAY ĐỔI SẢN PHẨM
            tbody.addEventListener('click', function (e) {
                const btn = e.target.closest('.btn-remove-row');
                if (btn && !btn.disabled) {
                    btn.closest('tr').remove();
                    updateRows();
                }
            });

            tbody.addEventListener('change', function (e) {
                if (e.target.classList.contains('product-select')) {
                    const select = e.target;
                    const row = select.closest('tr');
                    const stockDisplay = row.querySelector('.stock-display');
                    const qtyInput = row.querySelector('.qty-input');

                    const selectedOption = select.options[select.selectedIndex];
                    const maxStock = selectedOption.getAttribute('data-stock');

                    if (select.value !== "") {
                        stockDisplay.textContent = maxStock;
                        qtyInput.disabled = false;
                        qtyInput.max = maxStock; 
                        qtyInput.value = 1;      
                    }
                }
            });

            tbody.addEventListener('input', function (e) {
                if (e.target.classList.contains('qty-input')) {
                    const input = e.target;
                    const max = parseInt(input.max);
                    if (parseInt(input.value) > max) {
                        alert(`LỖI: Kho chỉ còn ${max} sản phẩm! Không thể xuất lố.`);
                        input.value = max; 
                    }
                }
            });

            exportForm.addEventListener('submit', function (e) {
                e.preventDefault(); 

                const visibleInputs = document.querySelectorAll('.serial-input-hidden');
                visibleInputs.forEach(input => {
                    const val = input.value.replace(',', '').trim().toUpperCase();
                    if (val) {
                        const container = input.parentElement;
                        const hiddenInput = container.nextElementSibling;
                        
                        const tag = document.createElement('span');
                        tag.className = 'serial-tag text-dark fw-bold';
                        tag.innerHTML = `${val} <i class="bi bi-x fs-6" onclick="removeSerialTag(this)"></i>`;
                        container.insertBefore(tag, input);
                        input.value = ''; 
                        updateHiddenSerial(container, hiddenInput);
                    }
                });

                const btnSubmit = this.querySelector('button[type="submit"]');
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...';

                this.submit(); 
            });
        });

        // TÁCH RA KHỎI DOMContentLoaded ĐỂ CHẠY RIÊNG CHO SERIAL
        document.addEventListener('keydown', function(e) {
            if (e.target.classList.contains('serial-input-hidden')) {
                const input = e.target;
                const container = input.parentElement;
                const hiddenInput = container.nextElementSibling;
                const row = input.closest('tr');
                const qtyInput = row.querySelector('.qty-input');
                
                if (e.key === 'Enter' || e.key === ',') {
                    e.preventDefault(); 
                    
                    const val = input.value.replace(',', '').trim().toUpperCase(); 
                    
                    if (val) {
                        const currentTagsCount = container.querySelectorAll('.serial-tag').length;
                        const maxAllowed = parseInt(qtyInput.value) || 0;

                        if (currentTagsCount >= maxAllowed) {
                            alert(`⚠️ LỖI: Bạn đã chọn xuất [${maxAllowed}] thiết bị, nên chỉ được nhập tối đa ${maxAllowed} mã SN!`);
                            input.value = ''; 
                            return;
                        }

                        const snRegex = /^[A-Z0-9]{15}$/;
                        if (!snRegex.test(val)) {
                            alert(`❌ Số SN [ ${val} ] không hợp lệ!\nVui lòng nhập đúng 15 ký tự bao gồm chữ cái và số.`);
                            return; 
                        }

                        const existingTags = Array.from(container.querySelectorAll('.serial-tag')).map(t => t.innerText.replace(' x', '').trim());
                        if (existingTags.includes(val)) {
                            alert(`⚠️ Số SN [ ${val} ] này đã được nhập rồi!`);
                            return;
                        }

                        const tag = document.createElement('span');
                        tag.className = 'serial-tag text-dark fw-bold';
                        tag.innerHTML = `${val} <i class="bi bi-x fs-6" onclick="removeSerialTag(this)"></i>`;
                        
                        container.insertBefore(tag, input);
                        input.value = ''; 
                        
                        updateHiddenSerial(container, hiddenInput);
                    }
                }
            }
        });

        window.removeSerialTag = function(icon) {
            const container = icon.closest('.serial-tag-container');
            const hiddenInput = container.nextElementSibling;
            icon.parentElement.remove();
            updateHiddenSerial(container, hiddenInput);
        };

        function updateHiddenSerial(container, hiddenInput) {
            const tags = Array.from(container.querySelectorAll('.serial-tag')).map(t => t.innerText.replace(' x', '').trim());
            hiddenInput.value = tags.join(',');
        }
    </script>
</body>
</html>