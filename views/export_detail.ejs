<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <title>
        <%= title %> | Kho FTEL
    </title>
</head>

<body>
    <div class="container mt-4 mb-5">

        <div class="d-flex justify-content-between mb-3">
            <a href="/exportstock" class="btn btn-secondary shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <button onclick="exportPDF()" class="btn btn-danger shadow-sm fw-bold">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i> Tải file PDF
            </button>
        </div>

        <div class="card border-0 shadow-lg rounded-0" id="phieu-xuat-pdf">
            <div class="card-body p-5">

                <div class="row border-bottom pb-3 mb-4">
                    <div class="col-6">
                        <img src="/images/fpt.png" alt="FPT" height="40" class="me-2 mb-2">
                        <h5 class="fw-bold mb-0">FPT Telecom An Giang</h5>
                        <p class="mb-0 text-muted" style="font-size: 0.9rem;">Địa chỉ: 132 Trần Hưng Đạo, P.Long Xuyên,
                            An Giang</p>
                        <p class="mb-0 text-muted" style="font-size: 0.9rem;">SĐT: 0901 888 551</p>
                    </div>
                    <div class="col-6 text-end mt-4">
                        <p class="mb-0 fw-bold">Mã phiếu: <span class="text-danger">
                                <%= px.exportID %>
                            </span></p>
                        <p class="mb-0 text-muted" style="font-size: 0.9rem;">Ngày in: <%= new
                                Date().toLocaleDateString('vi-VN') %>
                        </p>
                    </div>
                </div>

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-uppercase">PHIẾU XUẤT KHO</h2>
                   
                </div>

                <div class="row mb-4">
                    <div class="col-md-12">
                        <table class="table table-borderless table-sm mb-0">
                            <tr>
                                <td style="width: 180px;" class="fw-semibold pb-1">Người nhận hàng:</td>
                                <td class="pb-1 fw-bold text-uppercase">
                                    <%= px.recipientName || '---' %>
                                        <% if (px.recipientPhone) { %> - SĐT: <%= px.recipientPhone %>
                                                <% } %>
                                </td>
                            </tr>
                            <tr>
                                <td class="fw-semibold pt-2 pb-0">Chứng từ gốc:</td>
                                <td class="pt-2 pb-0 fst-italic">
                                    Theo số hóa đơn <span class="fw-bold text-primary">
                                        <%= px.invoiceNumber || '......' %>
                                    </span>
                                    của <span class="fw-bold text-dark">Công Ty Cổ Phần Viễn Thông FPT Chi Nhánh An Giang</span>

                                    <span class="fst-italic text-muted">
                                        Ngày <%= new Date(px.dateExport).getDate() %>
                                            tháng <%= new Date(px.dateExport).getMonth() + 1 %>
                                                năm <%= new Date(px.dateExport).getFullYear() %>
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <td class="fw-semibold pb-1">Lý do xuất kho:</td>
                                <td class="pb-1">
                                    <%= px.reason || '---' %>
                                </td>
                            </tr>
                            <tr>
                                <td class="fw-semibold pb-1">Ghi chú:</td>
                                <td class="pb-1">
                                    <%= px.note || '---' %>
                                </td>
                            </tr>
                            <tr>
                                <td class="fw-semibold pt-3">Người lập phiếu:</td>
                                <td class="pt-3">
                                    <%= px.user ? (px.user.fullName || px.user.userName) : 'N/A' %>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <h6 class="fw-bold mb-3">Chi tiết vật tư xuất kho:</h6>
                <table class="table table-bordered align-middle">
                    <thead class="table-light text-center align-middle">
                        <tr>
                            <th scope="col" style="width: 5%">STT</th>
                            <th scope="col" style="width: 12%">Mã SP</th>
                            <th scope="col" style="width: 20%">Tên Thiết bị</th>
                            <th scope="col" style="width: 22%">Số SN</th>
                            <th scope="col" style="width: 8%">ĐVT</th>
                            <th scope="col" style="width: 8%">SL</th>
                            <th scope="col" style="width: 11%">Đơn giá (VNĐ)</th>
                            <th scope="col" style="width: 14%">Thành tiền (VNĐ)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% let totalQuantity=0; let totalAmount=0; %>
                            <% if (items && items.length> 0) { %>
                                <% items.forEach(function(item, index) { %>
                                    <% let unitPrice=item.price || (item.product ? item.product.price : 0) || 0; let
                                        displayProductName=(item.productName && item.productName !=='Sản phẩm không tên'
                                        ) ? item.productName : (item.product ? item.product.productName
                                        : 'Sản phẩm đã xóa/N/A' ); let displayProductID=(item.product &&
                                        item.product.productID) ? item.product.productID : 'N/A' ; let
                                        displayUnit=item.unitName ? item.unitName : ((item.product && item.product.unit)
                                        ? (item.product.unit.unitName || item.product.unit.name) : 'Cái' ); let
                                        qty=item.quantity || 0; let subTotal=qty * unitPrice; totalQuantity +=qty;
                                        totalAmount +=subTotal; %>
                                        <tr>
                                            <td class="text-center">
                                                <%= index + 1 %>
                                            </td>
                                            <td class="text-center">
                                                <%= displayProductID %>
                                            </td>
                                            <td class="fw-semibold">
                                                <%= displayProductName %>
                                            </td>

                                            <td class="text-break text-muted" style="font-size: 0.85rem;">
                                                <%= item.serialNumber ? item.serialNumber.split(',').join(', ') : ' ---'
                                                    %>
                                            </td>

                                            <td class="text-center">
                                                <%= displayUnit %>
                                            </td>
                                            <td class="text-center fw-bold">
                                                <%= qty %>
                                            </td>
                                            <td class="text-end">
                                                <%= (unitPrice || 0).toLocaleString('vi-VN') %>
                                            </td>
                                            <td class="text-end fw-semibold text-primary">
                                                <%= (subTotal || 0).toLocaleString('vi-VN') %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" class="text-center text-muted py-4">Không có dữ liệu
                                                        thiết bị!</td>
                                                </tr>
                                                <% } %>

                                                    <tr class="table-warning fw-bold">
                                                        <td colspan="5" class="text-end">TỔNG CỘNG:</td>
                                                        <td class="text-center text-danger">
                                                            <%= totalQuantity %>
                                                        </td>
                                                        <td></td>
                                                        <td class="text-end fs-5 text-danger">
                                                            <%= (totalAmount || 0).toLocaleString('vi-VN') %> ₫
                                                        </td>
                                                    </tr>
                    </tbody>
                </table>

                <div class="row mt-5 text-center" style="margin-bottom: 80px;">
                    <div class="col-3">
                        <p class="fw-bold mb-0">Người nhận hàng</p>
                        <small class="text-muted fst-italic">(Ký, họ tên)</small>
                    </div>
                    <div class="col-3">
                        <p class="fw-bold mb-0">Người lập phiếu</p>
                        <small class="text-muted fst-italic">(Ký, họ tên)</small>
                    </div>
                    <div class="col-3">
                        <p class="fw-bold mb-0">Thủ kho</p>
                        <small class="text-muted fst-italic">(Ký, họ tên)</small>
                    </div>
                    <div class="col-3">
                        <p class="fw-bold mb-0">Kế toán trưởng</p>
                        <small class="text-muted fst-italic">(Ký, họ tên)</small>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        function exportPDF() {
            const element = document.getElementById('phieu-xuat-pdf');
            const opt = {
                margin: [10, 10, 10, 10],
                filename: 'PhieuXuatKho_<%= px.exportID %>.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' } // Landscape rất hợp lý vì có cột Serial dài
            };

            // Tạm thời ẩn các viền bóng đổ để PDF in ra sạch đẹp
            element.style.border = 'none';
            element.classList.remove('shadow-lg');

            html2pdf().set(opt).from(element).save().then(() => {
                // Khôi phục lại giao diện sau khi tải xong
                element.classList.add('shadow-lg');
            });
        }
    </script>
</body>

</html>