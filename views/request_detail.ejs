<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <title><%= title %> | Kho FTEL</title>
</head>

<body class="bg-light">
    <div class="container mt-4 mb-5" style="max-width: 1000px;">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <a href="/request" class="btn btn-secondary shadow-sm fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>
            <div class="d-flex gap-2">
                <% if (currentUser.role === 'admin' && request.status === 'pending') { %>
                    <a href="/request/tu-choi/<%= request._id %>" class="btn btn-danger shadow-sm fw-bold" onclick="return confirm('Bạn có chắc chắn muốn TỪ CHỐI phiếu này?')">
                        <i class="bi bi-x-circle me-1"></i> Từ chối
                    </a>
                    <a href="/request/duyet/<%= request._id %>" class="btn btn-success shadow-sm fw-bold" onclick="return confirm('Xác nhận DUYỆT yêu cầu NHẬP HÀNG này?')">
                        <i class="bi bi-check-circle me-1"></i> Duyệt Yêu Cầu
                    </a>
                <% } %>
                <button onclick="exportPDF()" class="btn btn-primary shadow-sm fw-bold">
                    <i class="bi bi-file-earmark-pdf-fill me-1"></i> Tải file PDF
                </button>
            </div>
        </div>

        <div class="card border-0 shadow-lg rounded-0" id="phieu-yeu-cau-pdf">
            <div class="card-body p-5">

                <div class="row border-bottom pb-3 mb-4">
                    <div class="col-7">
                        <img src="/images/fpt.png" alt="FPT" height="40" class="me-2 mb-2">
                        <h5 class="fw-bold mb-0">FPT Telecom An Giang</h5>
                        <p class="mb-0 text-muted" style="font-size: 0.9rem;">Địa chỉ: 132 Trần Hưng Đạo, P.Long Xuyên, An Giang</p>
                        <p class="mb-0 text-muted" style="font-size: 0.9rem;">SĐT: 0901 888 551</p>
                    </div>
                    <div class="col-5 text-end mt-2">
                        <p class="mb-1 fw-bold fs-5">Mã phiếu: <span class="text-danger"><%= request.requestID %></span></p>
                        <p class="mb-0 text-muted" style="font-size: 0.9rem;">Ngày in: <%= new Date().toLocaleDateString('vi-VN') %></p>
                        <p class="mb-0 fw-semibold mt-1" style="font-size: 0.9rem;">Trạng thái: 
                            <% if (request.status === 'pending') { %>
                                <span class="text-warning">Chờ duyệt</span>
                            <% } else if (request.status === 'approved') { %>
                                <span class="text-success">Đã duyệt</span>
                            <% } else { %>
                                <span class="text-danger">Đã từ chối</span>
                            <% } %>
                        </p>
                    </div>
                </div>

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-uppercase text-primary">PHIẾU YÊU CẦU NHẬP HÀNG</h2>
                    <p class="fst-italic text-muted">Ngày &nbsp; <%= new Date(request.dateCreated).getDate() %> tháng 
                                                                  <%= new Date(request.dateCreated).getMonth() + 1 %> năm 
                                                                  <%= new Date(request.dateCreated).getFullYear() %></p>
                </div>

                <div class="row mb-4">
                    <div class="col-md-12">
                        <table class="table table-borderless table-sm mb-0">
                            <tr>
                                <td style="width: 150px;" class="fw-semibold pb-0">Người đề xuất:</td>
                                <td class="pb-0 fw-bold"><%= request.user ? (request.user.fullName || request.user.userName) : 'N/A' %></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold pt-2 pb-0">Lý do yêu cầu:</td>
                                <td class="pt-2 pb-0 fst-italic">"<%= request.note || 'Không có ghi chú' %>"</td>
                            </tr>
                            <% if (request.status !== 'pending') { %>
                            <tr>
                                <td class="fw-semibold pt-2">Người xử lý</td>
                                <td class="pt-2 text-primary fw-bold"><%= request.handledBy ? (request.handledBy.fullName || request.handledBy.userName) : 'N/A' %></td>
                            </tr>
                            <% } %>
                        </table>
                    </div>
                </div>

                <h6 class="fw-bold mb-3">Danh sách thiết bị đề xuất nhập:</h6>
                <table class="table table-bordered align-middle">
                    <thead class="table-light text-center align-middle">
                        <tr>
                            <th scope="col" style="width: 5%">STT</th>
                            <th scope="col" style="width: 15%">Mã SP</th>
                            <th scope="col" style="width: 35%">Tên Thiết bị</th>
                            <th scope="col" style="width: 10%">ĐVT</th>
                            <th scope="col" style="width: 10%">Số lượng</th>
                            <th scope="col" style="width: 10%">Đơn giá (VNĐ)</th>
                            <th scope="col" style="width: 15%">Thành tiền (VNĐ)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% 
                            let totalQuantity = 0; 
                            let totalAmount = 0; 
                        %>
                        <% if (requestItems && requestItems.length > 0) { %>
                            <% requestItems.forEach(function(item, index) { %>
                                <% 
                                    let unitPrice = item.price || ((item.product && item.product.price) ? item.product.price : 0);
                                    let displayProductName = item.productName || (item.product ? item.product.productName : 'Sản phẩm đã bị xóa');
                                    let displayUnit = item.unitName || ((item.product && item.product.unit) ? (item.product.unit.unitName || item.product.unit.name) : 'Cái');
                                    let displayProductID = item.product ? item.product.productID : 'N/A'; 

                                    let subTotal = item.quantity * unitPrice;
                                    totalQuantity += item.quantity;
                                    totalAmount += subTotal;
                                %>
                                <tr>
                                    <td class="text-center"><%= index + 1 %></td>
                                    <td class="text-center"><%= displayProductID %></td>
                                    <td class="fw-semibold"><%= displayProductName %></td>
                                    <td class="text-center"><%= displayUnit %></td>
                                    <td class="text-center fw-bold text-primary"><%= item.quantity %></td>
                                    <td class="text-end"><%= unitPrice.toLocaleString('vi-VN') %></td>
                                    <td class="text-end fw-semibold text-danger"><%= subTotal.toLocaleString('vi-VN') %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center text-muted">Không có dữ liệu thiết bị!</td>
                            </tr>
                        <% } %>

                        <tr class="table-warning fw-bold">
                            <td colspan="4" class="text-end">TỔNG CỘNG:</td>
                            <td class="text-center text-primary fs-5"><%= totalQuantity %></td>
                            <td></td>
                            <td class="text-end fs-5 text-danger"><%= totalAmount.toLocaleString('vi-VN') %> ₫</td>
                        </tr>
                    </tbody>
                </table>

                <div class="row mt-5 text-center" style="margin-bottom: 80px;">
                    <div class="col-6">
                        <p class="fw-bold mb-0">Người lập</p>
                        <small class="text-muted fst-italic">(Ký, họ tên)</small>
                    </div>

                    <div class="col-6">
                        <p class="fw-bold mb-0">Giám đốc chi nhánh</p>
                        <small class="text-muted fst-italic">(Ký, họ tên)</small>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        function exportPDF() {
            const element = document.getElementById('phieu-yeu-cau-pdf');
            const opt = {
                margin: [10, 10, 10, 10],
                filename: 'PhieuYeuCauNhap_<%= request.requestID %>.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' } 
            };
            
            // Tạm thời xóa border/shadow để file PDF in ra phẳng và đẹp như tờ giấy A4
            element.style.border = 'none';
            element.classList.remove('shadow-lg');
            
            html2pdf().set(opt).from(element).save().then(() => {
                // Khôi phục lại giao diện hiển thị trên web
                element.classList.add('shadow-lg');
            });
        }
    </script>
</body>

</html>