<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <title>
        <%= title %> | Kho FTEL
    </title>
</head>

<body>
    <div class="container">
        <%- include('includes/header') %>
    </div>

    <%- include('includes/navbar') %>

        <% if (currentUser) { %>
            <div class="d-flex" style="height: calc(100vh - 140px);">

                <div class="sidebar d-flex flex-column p-3 h-100 overflow-auto">
                    <a href="/" class="d-flex align-items-center mb-4 text-decoration-none text-primary">
                        <div>
                            <img src="/images/fpt.png" alt="FPT" height="40" class="me-2">
                            <p style="color :black"><b>FPT Telecom An Giang</b></p>
                        </div>
                    </a>

                    <ul class="nav flex-column mb-auto">
                        <li class="nav-item">
                            <a href="#collapseDanhMuc" data-bs-toggle="collapse" aria-expanded="false"
                                class="nav-link d-flex justify-content-between align-items-center">
                                <div><i class="bi bi-list-ul text-secondary"></i> Hệ thống</div>
                                <i class="bi bi-caret-right-fill rotate-icon"
                                    style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                            </a>
                            <ul class="collapse nav flex-column ms-3" id="collapseDanhMuc">
                                <li class="nav-item"><a href="/provider" class="nav-link"><i
                                            class="bi bi-shop text-secondary"></i> Nhà cung cấp</a></li>
                                <li class="nav-item"><a href="/user" class="nav-link"><i
                                            class="bi bi-person-fill text-secondary"></i> Người dùng</a></li>
                                <li class="nav-item"><a href="/request" class="nav-link "><i
                                            class="bi bi-file-earmark-text text-secondary"></i> Yêu cầu nhập hàng</a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item mt-1">
                            <a href="#collapseKhoThietBi" data-bs-toggle="collapse" aria-expanded="true"
                                class="nav-link d-flex justify-content-between align-items-center">
                                <div><i class="bi bi-building text-secondary"></i> Kho thiết bị</div>
                                <i class="bi bi-caret-right-fill rotate-icon"
                                    style="font-size: 0.8rem; transition: transform 0.3s; transform: rotate(90deg);"></i>
                            </a>
                            <ul class="collapse show nav flex-column ms-3" id="collapseKhoThietBi">
                                <li class="nav-item"><a href="/unit" class="nav-link"><i
                                            class="bi bi-tag-fill text-secondary"></i> Đơn vị tính</a></li>
                                <li class="nav-item"><a href="/category" class="nav-link"><i
                                            class="bi bi-grid-fill text-secondary"></i> Danh mục thiết bị</a></li>
                                <li class="nav-item"><a href="/product" class="nav-link"><i
                                            class="bi bi-box-seam text-secondary"></i> Thiết bị</a></li>
                                <li class="nav-item"><a href="/inventory" class="nav-link"><i
                                            class="bi bi-boxes text-secondary"></i> Tồn kho</a></li>
                                <li class="nav-item"><a href="/importstock" class="nav-link"><i
                                            class="bi bi-box-arrow-in-right text-secondary"></i> Nhập kho</a></li>
                                <li class="nav-item"><a href="/exportstock" class="nav-link text-primary fw-bold"><i
                                            class="bi bi-box-arrow-right text-primary"></i> Xuất kho</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>

                <div class="main-content flex-grow-1 d-flex flex-column bg-light h-100 overflow-hidden">
                    <div
                        class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center flex-shrink-0">
                        <div>
                            <h4 class="mb-0 fw-bold text-danger"><i class="bi bi-trash3 me-2"></i>Thùng rác Xuất Kho
                            </h4>
                            <nav aria-label="breadcrumb" class="mt-2">
                                <ol class="breadcrumb mb-0">
                                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a>
                                    </li>
                                    <li class="breadcrumb-item"><a href="/exportstock" class="text-decoration-none">Xuất
                                            kho</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Thùng rác</li>
                                </ol>
                            </nav>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/exportstock" class="btn btn-secondary shadow-sm fw-semibold">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại
                            </a>
                        </div>
                    </div>

                    <div class="p-4 flex-grow-1 overflow-auto">

                        <div class="alert alert-warning border-warning border-start border-4 mb-4 bg-white shadow-sm">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-exclamation-triangle-fill fs-4 text-warning me-3"></i>
                                <div>
                                    <h6 class="alert-heading fw-bold mb-1">Cảnh báo Khôi phục Phiếu Xuất</h6>
                                    <p class="mb-0" style="font-size: 0.9rem;">
                                        Hệ thống sẽ kiểm tra xem trong kho còn đủ thiết bị hay không. Nếu đủ, việc
                                        <b>Khôi phục</b> phiếu xuất sẽ tự động <b class="text-danger">trừ lại</b> thiết
                                        bị trong kho.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm rounded-3">
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th scope="col" class="text-center py-3" style="width: 5%">STT</th>
                                                <th scope="col" class="py-3" style="width: 10%">Mã Phiếu</th>
                                                <th scope="col" class="py-3" style="width: 25%">Lý do hủy</th>
                                                <th scope="col" class="py-3" style="width: 15%">Ngày hủy</th>
                                                <th scope="col" class="py-3" style="width: 15%">Người hủy</th>
                                                <th scope="col" class="text-center py-3" style="width: 15%">Hành động
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (typeof exports !=='undefined' && exports.length> 0) { %>
                                                <% exports.forEach(function(px, index) { %>
                                                    <tr class="table-danger border-danger border-opacity-25">
                                                        <td class="text-center fw-semibold text-muted">
                                                            <%= index + 1 %>
                                                        </td>
                                                        <td>
                                                            <span
                                                                class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-2 py-1 fs-6 text-decoration-line-through">
                                                                <i class="bi bi-box-arrow-right me-1"></i>
                                                                <%= px.exportID %>
                                                            </span>
                                                        </td>

                                                        <td>
                                                            <span class="text-danger fw-semibold">
                                                                <%= px.cancelReason || 'Không ghi rõ lý do' %>
                                                            </span>
                                                        </td>

                                                        <td class="fw-semibold text-danger">
                                                            <%= new Date(px.cancelledAt ||
                                                                px.updatedAt).toLocaleDateString('vi-VN', {
                                                                day: '2-digit' , month: '2-digit' , year: 'numeric' ,
                                                                hour: '2-digit' , minute: '2-digit' }) %>
                                                        </td>

                                                        <td>
                                                            <span
                                                                class="badge bg-white text-danger border border-danger-subtle">
                                                                <i class="bi bi-person-x me-1"></i>
                                                                <%= px.cancelledBy ? (px.cancelledBy.fullName ||
                                                                    px.cancelledBy.userName) : (px.user ?
                                                                    px.user.userName : 'N/A' ) %>
                                                            </span>
                                                        </td>

                                                        <td class="text-center">
                                                            <div
                                                                class="d-flex justify-content-center align-items-center gap-2">
                                                                <a href="/exportstock/chitiet/<%= px._id %>"
                                                                    class="btn btn-outline-info btn-sm px-2 py-1 bg-white"
                                                                    title="Xem chi tiết">
                                                                    <i class="bi bi-eye"></i>
                                                                </a>

                                                                <a href="/exportstock/khoi-phuc/<%= px._id %>"
                                                                    class="btn btn-outline-success btn-sm px-2 py-1 bg-white"
                                                                    onclick="return confirm('Bạn có chắc chắn muốn khôi phục phiếu này? Việc này sẽ TRỪ LẠI số lượng thiết bị trong kho!')"
                                                                    title="Khôi phục phiếu">
                                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                                </a>
                                                                <a href="/importstock/xoa-an/<%= pn._id %>"
                                                                    class="btn btn-outline-danger btn-sm px-2 py-1 bg-white"
                                                                    onclick="return confirm('Bạn có chắc chắn muốn dọn dẹp phiếu này? (Phiếu sẽ bị ẩn hoàn toàn khỏi thùng rác)')"
                                                                    title="Xóa khỏi thùng rác">
                                                                    <i class="bi bi-trash"></i>
                                                                </a>
                                                                <a href="/exportstock/xoa-an/<%= px._id %>"
                                                                    class="btn btn-outline-danger btn-sm px-2 py-1 bg-white"
                                                                    onclick="return confirm('Bạn có chắc chắn muốn dọn dẹp phiếu này? (Phiếu sẽ bị ẩn hoàn toàn khỏi thùng rác)')"
                                                                    title="Xóa khỏi thùng rác">
                                                                    <i class="bi bi-trash"></i>
                                                                </a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="6" class="text-center py-5 text-muted">
                                                                    <i
                                                                        class="bi bi-emoji-smile fs-1 d-block mb-3 text-success opacity-50"></i>
                                                                    Tuyệt vời! Thùng rác đang trống.
                                                                </td>
                                                            </tr>
                                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <% } else { %>
                <div class="container mt-5 text-center">
                    <div class="alert alert-warning" role="alert">
                        Vui lòng <a href="/auth/login" class="alert-link">đăng nhập</a> để truy cập hệ thống.
                    </div>
                </div>
                <% } %>

                    <%- include('includes/footer') %>
                        <%- include('includes/javascript') %>
</body>

</html>