<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <title>
        <%= title %> | Kho FTEL
    </title>
</head>

<body>
    <div class="container">
        <%- include('includes/header') %>
    </div>

    <%- include('includes/navbar') %>

        <% if (currentUser) { %>
            <div class="d-flex" style="height: calc(100vh - 140px);">

                <div class="sidebar d-flex flex-column p-3 h-100 overflow-auto">
                    <a href="/" class="d-flex align-items-center mb-4 text-decoration-none text-primary">
                    <div>
                        <img src="/images/fpt.png" alt="FPT" height="40" class="me-2">
                        <p style="color :black"><b>FPT Telecom An Giang</b></p>
                    </div>
                </a>

                    <ul class="nav flex-column mb-auto">
                        <li class="nav-item">
                            <a href="#collapseDanhMuc" data-bs-toggle="collapse" aria-expanded="false" class="nav-link d-flex justify-content-between align-items-center">
                                <div><i class="bi bi-list-ul text-secondary"></i> Hệ thống</div>
                                <i class="bi bi-caret-right-fill rotate-icon" style="font-size: 0.8rem; transition: transform 0.3s;"></i>
                            </a>
                            <ul class="collapse nav flex-column ms-3" id="collapseDanhMuc">
                                <li class="nav-item"><a href="/provider" class="nav-link"><i class="bi bi-shop text-secondary"></i> Nhà cung cấp</a></li>
                                <li class="nav-item"><a href="/user" class="nav-link"><i class="bi bi-person-fill text-secondary"></i> Người dùng</a></li>
                                <li class="nav-item">
                                    <a href="/request" class="nav-link text-primary fw-bold">
                                        <i class="bi bi-file-earmark-text text-primary"></i>Yêu cầu nhập hàng
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item mt-1">
                            <a href="#collapseKhoThietBi" data-bs-toggle="collapse" aria-expanded="true" class="nav-link d-flex justify-content-between align-items-center">
                                <div><i class="bi bi-building text-secondary"></i> Kho thiết bị</div>
                                <i class="bi bi-caret-right-fill rotate-icon" style="font-size: 0.8rem; transition: transform 0.3s; transform: rotate(90deg);"></i>
                            </a>
                            <ul class="collapse show nav flex-column ms-3" id="collapseKhoThietBi">
                                <li class="nav-item"><a href="/unit" class="nav-link"><i class="bi bi-tag-fill text-secondary"></i> Đơn vị tính</a></li>
                                <li class="nav-item"><a href="/category" class="nav-link"><i class="bi bi-grid-fill text-secondary"></i> Danh mục thiết bị</a></li>
                                <li class="nav-item"><a href="/product" class="nav-link"><i class="bi bi-box-seam text-secondary"></i> Thiết bị</a></li>
                                <li class="nav-item"><a href="/inventory" class="nav-link"><i class="bi bi-boxes text-secondary"></i> Tồn kho</a></li>
                                <li class="nav-item"><a href="/importstock" class="nav-link"><i class="bi bi-box-arrow-in-right text-secondary"></i> Nhập kho</a></li>
                                <li class="nav-item"><a href="/exportstock" class="nav-link"><i class="bi bi-box-arrow-right text-secondary"></i> Xuất kho</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>

                <div class="main-content flex-grow-1 d-flex flex-column bg-light h-100 overflow-hidden">
                    <div class="p-4 border-bottom bg-white flex-shrink-0">
                        <h4 class="mb-0 fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>Sửa Phiếu Yêu Cầu</h4>
                        <nav aria-label="breadcrumb" class="mt-2">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
                                <li class="breadcrumb-item"><a href="/request" class="text-decoration-none">Phiếu yêu cầu</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Sửa phiếu: <%= request.requestID %></li>
                            </ol>
                        </nav>
                    </div>
                    
                    <div class="p-4 flex-grow-1 overflow-auto">
                        <div class="card border-0 shadow-sm rounded-3">
                            <div class="card-body p-4">
                                <form action="/request/sua/<%= request._id %>" method="POST" id="requestForm">
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold text-dark">Mã phiếu</label>
                                            <input type="text" class="form-control border-secondary-subtle bg-light" value="<%= request.requestID %>" readonly>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold text-dark">Người lập phiếu</label>
                                            <input type="text" class="form-control border-secondary-subtle bg-light" value="<%= currentUser.name || currentUser.fullName || currentUser.userName %>" readonly>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-bold text-dark">Ghi chú / Lý do</label>
                                        <textarea name="note" class="form-control border-secondary-subtle" rows="2" placeholder="..."><%= request.note %></textarea>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                                        <h5 class="fw-bold text-primary mb-0"><i class="bi bi-boxes me-2"></i>Danh sách thiết bị</h5>
                                        <button type="button" class="btn btn-sm btn-outline-primary fw-semibold" id="btnAddRow">
                                            <i class="bi bi-plus-lg me-1"></i> Thêm dòng
                                        </button>
                                    </div>

                                    <div class="table-responsive mb-4">
                                        <table class="table table-bordered align-middle" id="productTable">
                                            <thead class="table-light text-center">
                                                <tr>
                                                    <th style="width: 5%">STT</th>
                                                    <th style="width: 60%">Tên thiết bị</th>
                                                    <th style="width: 25%">Số lượng</th>
                                                    <th style="width: 10%">Xóa</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tableBody">
                                                
                                                <% if (typeof requestItems !== 'undefined' && requestItems.length > 0) { %>
                                                    <% requestItems.forEach(function(item, index) { %>
                                                        <tr class="product-row">
                                                            <td class="text-center row-number fw-semibold text-muted"><%= index + 1 %></td>
                                                            <td>
                                                                <select name="productID" class="form-select border-secondary-subtle product-select" required>
                                                                    <option value="" disabled>-- Lựa chọn thiết bị --</option>
                                                                    <% if (typeof products !== 'undefined' && products.length > 0) { %>
                                                                        <% products.forEach(p => { %>
                                                                            <% let isSelected = (item.product && item.product.toString() === p._id.toString()) ? 'selected' : ''; %>
                                                                            <option value="<%= p._id %>" <%= isSelected %>>
                                                                                <%= p.productName || p.name %> (Tồn: <%= p.inventoryQuantity || '0' %>)
                                                                            </option>
                                                                        <% }) %>
                                                                    <% } %>
                                                                </select>
                                                            </td>
                                                            <td>
                                                                <input type="number" name="quantity" class="form-control border-secondary-subtle text-center" min="1" value="<%= item.quantity %>" required>
                                                            </td>
                                                            <td class="text-center">
                                                                <button type="button" class="btn btn-outline-danger btn-sm btn-remove-row" <%= requestItems.length === 1 ? 'disabled' : '' %>>
                                                                    <i class="bi bi-trash3"></i>
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    <% }) %>
                                                <% } else { %>
                                                    <tr class="product-row">
                                                        <td class="text-center row-number fw-semibold text-muted">1</td>
                                                        <td>
                                                            <select name="productID" class="form-select border-secondary-subtle product-select" required>
                                                                <option value="" disabled selected>-- Lựa chọn thiết bị --</option>
                                                                <% products.forEach(p => { %>
                                                                    <option value="<%= p._id %>"><%= p.productName || p.name %> (Tồn: <%= p.inventoryQuantity || '0' %>)</option>
                                                                <% }) %>
                                                            </select>
                                                        </td>
                                                        <td><input type="number" name="quantity" class="form-control border-secondary-subtle text-center" min="1" value="1" required></td>
                                                        <td class="text-center"><button type="button" class="btn btn-outline-danger btn-sm btn-remove-row" disabled><i class="bi bi-trash3"></i></button></td>
                                                    </tr>
                                                <% } %>

                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                                        <a href="/request" class="btn btn-light border fw-semibold text-secondary">
                                            <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                                        </a>
                                        <button type="submit" class="btn btn-warning fw-bold shadow-sm text-dark">
                                            <i class="bi bi-save me-1"></i> Lưu Thay Đổi
                                        </button>
                                    </div>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

        <% } else { %>
            <div class="container mt-5 text-center">
                <div class="alert alert-warning" role="alert">
                    Vui lòng <a href="/auth/login" class="alert-link">đăng nhập</a> để truy cập hệ thống.
                </div>
            </div>
        <% } %>

        <%- include('includes/footer') %>
        <%- include('includes/javascript') %>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const btnAddRow = document.getElementById('btnAddRow');
                const tableBody = document.getElementById('tableBody');

                function updateRowNumbers() {
                    const rows = tableBody.querySelectorAll('.product-row');
                    rows.forEach((row, index) => {
                        row.querySelector('.row-number').textContent = index + 1;
                        const btnRemove = row.querySelector('.btn-remove-row');
                        if (rows.length === 1) {
                            btnRemove.setAttribute('disabled', 'true');
                        } else {
                            btnRemove.removeAttribute('disabled');
                        }
                    });
                }

                btnAddRow.addEventListener('click', function () {
                    const firstRow = tableBody.querySelector('.product-row');
                    const newRow = firstRow.cloneNode(true); 

                    // Reset giá trị về mặc định cho dòng mới copy ra
                    newRow.querySelector('select').selectedIndex = 0;
                    newRow.querySelector('input[type="number"]').value = 1;

                    tableBody.appendChild(newRow);
                    updateRowNumbers();
                });

                tableBody.addEventListener('click', function (e) {
                    const btn = e.target.closest('.btn-remove-row');
                    if (btn) {
                        const rows = tableBody.querySelectorAll('.product-row');
                        if (rows.length > 1) {
                            btn.closest('tr').remove();
                            updateRowNumbers();
                        }
                    }
                });
            });
        </script>
</body>
</html>