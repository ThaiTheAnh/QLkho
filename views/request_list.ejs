<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <title>
        <%= title %> | Kho FTEL
    </title>
</head>

<body>
    <div class="container">
        <%- include('includes/header') %>
    </div>

    <%- include('includes/navbar') %>

        <% if (currentUser) { %>
            <div class="d-flex" style="height: calc(100vh - 140px);">

                <div class="sidebar d-flex flex-column p-3 h-100 overflow-auto">
                    <a href="/" class="d-flex align-items-center mb-4 text-decoration-none text-primary">
                    <div>
                        <img src="/images/fpt.png" alt="FPT" height="40" class="me-2">
                        <p style="color :black"><b>FPT Telecom An Giang</b></p>
                    </div>
                </a>

                    <ul class="nav flex-column mb-auto">
                        <li class="nav-item">
                            <a href="#collapseDanhMuc" data-bs-toggle="collapse" aria-expanded="true"
                                class="nav-link d-flex justify-content-between align-items-center">
                                <div><i class="bi bi-list-ul text-secondary"></i> Hệ thống</div>
                                <i class="bi bi-caret-right-fill rotate-icon"
                                    style="font-size: 0.8rem; transition: transform 0.3s; transform: rotate(90deg);"></i>
                            </a>
                            <ul class="collapse show nav flex-column ms-3" id="collapseDanhMuc">
                                <li class="nav-item"><a href="/provider" class="nav-link"><i
                                            class="bi bi-shop text-secondary"></i> Nhà cung cấp</a></li>
                                <li class="nav-item"><a href="/user" class="nav-link"><i
                                            class="bi bi-person-fill text-secondary"></i> Người dùng</a></li>
                                <li class="nav-item">
                                    <a href="/request" class="nav-link text-primary fw-bold">
                                        <i class="bi bi-file-earmark-text text-primary"></i> Yêu cầu nhập hàng
                                    </a>
                                </li>
                            </ul>

                        </li>

                        <li class="nav-item mt-1">
                            <a href="#collapseKhoThietBi" data-bs-toggle="collapse" aria-expanded="true"
                                class="nav-link d-flex justify-content-between align-items-center">
                                <div><i class="bi bi-building text-secondary"></i> Kho thiết bị</div>
                                <i class="bi bi-caret-right-fill rotate-icon"
                                    style="font-size: 0.8rem; transition: transform 0.3s; transform: rotate(90deg);"></i>
                            </a>
                            <ul class="collapse show nav flex-column ms-3" id="collapseKhoThietBi">
                                <li class="nav-item"><a href="/unit" class="nav-link"><i
                                            class="bi bi-tag-fill text-secondary"></i> Đơn vị tính</a></li>
                                <li class="nav-item"><a href="/category" class="nav-link"><i
                                            class="bi bi-grid-fill text-secondary"></i> Danh mục thiết bị</a></li>
                                <li class="nav-item"><a href="/product" class="nav-link"><i
                                            class="bi bi-box-seam text-secondary"></i> Thiết bị</a></li>
                                <li class="nav-item"><a href="/inventory" class="nav-link"><i
                                            class="bi bi-boxes text-secondary"></i> Tồn kho</a></li>
                                <li class="nav-item"><a href="/importstock" class="nav-link"><i
                                            class="bi bi-box-arrow-in-right text-secondary"></i> Nhập kho</a></li>
                                <li class="nav-item"><a href="/exportstock" class="nav-link"><i
                                            class="bi bi-box-arrow-right text-secondary"></i> Xuất kho</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>

                <div class="main-content flex-grow-1 d-flex flex-column bg-light h-100 overflow-hidden">
                    <div
                        class="p-4 border-bottom bg-white d-flex justify-content-between align-items-center flex-shrink-0">
                        <div>
                            <h4 class="mb-0 fw-bold text-primary"><i class="bi bi-file-earmark-text me-2"></i>Danh sách
                                Phiếu Yêu Cầu</h4>
                            <nav aria-label="breadcrumb" class="mt-2">
                                <ol class="breadcrumb mb-0">
                                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a>
                                    </li>
                                    <li class="breadcrumb-item active" aria-current="page">Phiếu yêu cầu</li>
                                </ol>
                            </nav>
                        </div>
                        <div>
                            <a href="/request/them" class="btn btn-primary shadow-sm fw-semibold">
                                <i class="bi bi-plus-circle me-1"></i> Lập Yêu Cầu
                            </a>
                        </div>
                    </div>

                    <div class="px-4 pt-4">
                        <div class="card border-0 shadow-sm rounded-3 bg-white">
                            <div class="card-body p-3">
                                <form action="/request" method="GET" class="row g-2 align-items-end">
                                    <div class="col-md-4">
                                        <label class="form-label text-muted fw-semibold mb-1"
                                            style="font-size: 0.85rem;">
                                            <i class="bi bi-search me-1"></i>Từ khóa
                                        </label>
                                        <input type="text" name="search" class="form-control"
                                            placeholder="Mã phiếu, Người lập..."
                                            value="<%= (typeof filters !== 'undefined' && filters.search) ? filters.search : '' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted fw-semibold mb-1"
                                            style="font-size: 0.85rem;">
                                            <i class="bi bi-calendar-event me-1"></i>Từ ngày
                                        </label>
                                        <input type="date" name="fromDate" class="form-control"
                                            value="<%= (typeof filters !== 'undefined' && filters.fromDate) ? filters.fromDate : '' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted fw-semibold mb-1"
                                            style="font-size: 0.85rem;">
                                            <i class="bi bi-calendar-check me-1"></i>Đến ngày
                                        </label>
                                        <input type="date" name="toDate" class="form-control"
                                            value="<%= (typeof filters !== 'undefined' && filters.toDate) ? filters.toDate : '' %>">
                                    </div>
                                    <div class="col-md-2 d-flex gap-2">
                                        <button type="submit" class="btn btn-primary flex-grow-1 fw-semibold shadow-sm">
                                            <i class="bi bi-funnel-fill"></i> Lọc
                                        </button>
                                        <a href="/request"
                                            class="btn btn-light border flex-grow-1 fw-semibold text-secondary"
                                            title="Hủy bộ lọc">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 flex-grow-1 overflow-auto">
                        <div class="card border-0 shadow-sm rounded-3">
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th scope="col" class="text-center py-3" style="width: 5%">STT</th>
                                                <th scope="col" class="py-3" style="width: 12%">Mã phiếu</th>
                                                <th scope="col" class="py-3" style="width: 15%">Ngày lập</th>
                                                <th scope="col" class="py-3" style="width: 18%">Người lập</th>
                                                <th scope="col" class="py-3" style="width: 15%">Trạng thái</th>
                                                <th scope="col" class="text-center py-3" style="width: 25%">Hành động</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (typeof requests !=='undefined' && requests.length> 0) { %>
                                                <% requests.forEach(function(reqItem, index) { %>
                                                    <tr>
                                                        <td class="text-center fw-semibold text-muted">
                                                            <%= index + 1 %>
                                                        </td>
                                                        <td>
                                                            <span
                                                                class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-2 py-1 fs-6">
                                                                <i class="bi bi-hash"></i>
                                                                <%= reqItem.requestID %>
                                                            </span>
                                                        </td>
                                                        <td class="fw-semibold text-dark">
                                                            <%= new Date(reqItem.dateCreated).toLocaleDateString('vi-VN', {
                                                                day: '2-digit' , month: '2-digit' , year: 'numeric' })
                                                            %>
                                                        </td>
                                                        <td>
                                                            <span class="badge bg-light text-dark border">
                                                                <i class="bi bi-person me-1"></i>
                                                                <%= reqItem.user ? reqItem.user.fullName : 'N/A' %>
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <% if (reqItem.status==='pending' ) { %>
                                                                <span class="badge bg-warning text-dark px-2 py-1">
                                                                    <i class="bi bi-hourglass-split"></i> Chờ duyệt
                                                                </span>
                                                            <% } else if (reqItem.status==='approved' ) { %>
                                                                <span class="badge bg-success px-2 py-1">
                                                                    <i class="bi bi-check-circle"></i> Đã duyệt
                                                                </span>
                                                            <% } else { %>
                                                                <span class="badge bg-danger px-2 py-1">
                                                                    <i class="bi bi-x-circle"></i> Từ chối
                                                                </span>
                                                            <% } %>
                                                        </td>

                                                        <td class="text-center">
                                                            
                                                            <a href="/request/chitiet/<%= reqItem._id %>"
                                                                class="btn btn-outline-info btn-sm"
                                                                title="Xem chi tiết">
                                                                <i class="bi bi-eye"></i>
                                                            </a>

                                                            <% 
                                                                let isCreator = reqItem.user && currentUser && reqItem.user._id.toString() === currentUser._id.toString();
                                                                let isAdmin = currentUser && currentUser.role === 'admin';
                                                            %>
                                                            
                                                            <% if (reqItem.status === 'pending' && (isCreator || isAdmin)) { %>
                                                                <a href="/request/sua/<%= reqItem._id %>" 
                                                                   class="btn btn-warning btn-sm ms-1 text-dark" 
                                                                   title="Sửa phiếu">
                                                                    <i class="bi bi-pencil-square"></i>
                                                                </a>
                                                                <a href="/request/xoa/<%= reqItem._id %>" 
                                                                   class="btn btn-danger btn-sm ms-1" 
                                                                   onclick="return confirm('Bạn có chắc chắn muốn XÓA phiếu yêu cầu này không?');"
                                                                   title="Xóa phiếu">
                                                                    <i class="bi bi-trash3"></i>
                                                                </a>
                                                            <% } %>

                                                            <% if (isAdmin && reqItem.status === 'pending') { %>
                                                                <a href="/request/duyet/<%= reqItem._id %>"
                                                                    class="btn btn-success btn-sm ms-1"
                                                                    onclick="return confirm('Xác nhận DUYỆT phiếu này?')"
                                                                    title="Duyệt phiếu">
                                                                    <i class="bi bi-check2"></i>
                                                                </a>
                                                                <a href="/request/tu-choi/<%= reqItem._id %>"
                                                                    class="btn btn-dark btn-sm ms-1"
                                                                    onclick="return confirm('Xác nhận TỪ CHỐI phiếu này?')"
                                                                    title="Từ chối phiếu">
                                                                    <i class="bi bi-x-lg"></i>
                                                                </a>
                                                            <% } %>

                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="7" class="text-center py-5 text-muted">
                                                        <i class="bi bi-inbox fs-1 d-block mb-3 text-secondary"></i>
                                                        Chưa có phiếu yêu cầu nào.
                                                    </td>
                                                </tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <% } else { %>
                <div class="container mt-5 text-center">
                    <div class="alert alert-warning" role="alert">
                        Vui lòng <a href="/auth/login" class="alert-link">đăng nhập</a> để truy cập hệ thống.
                    </div>
                </div>
            <% } %>

            <%- include('includes/footer') %>
            <%- include('includes/javascript') %>
</body>
</html>